---
import type { CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import YouTubeEmbed from '../components/YouTubeEmbed.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';
import ContactForm from '../components/ContactForm.astro';
import { SITE_URL } from '../consts';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, youtubeId, tags, canonical, faqs } = Astro.props;
---

<BaseLayout title={`${title} | 512 Austin Home`} description={description} canonical={canonical} type="article">
	<SchemaMarkup type="article" data={{
		title,
		description,
		pubDate: pubDate.toISOString(),
		updatedDate: updatedDate?.toISOString(),
		image: heroImage ? new URL(heroImage.src, SITE_URL).href : undefined,
		youtubeId,
		url: new URL(Astro.url.pathname, SITE_URL).href,
	}} />
	<SchemaMarkup type="breadcrumb" data={{
		items: [
			{ name: 'Home', url: '/' },
			{ name: 'Blog', url: '/blog/' },
			{ name: title, url: Astro.url.pathname },
		],
	}} />
	{faqs && faqs.length > 0 && (
		<SchemaMarkup type="faq" data={{ questions: faqs }} />
	)}

	<article class="max-w-3xl mx-auto px-5 sm:px-8 py-16">
		<!-- Header -->
		<header class="mb-10">
			{tags && tags.length > 0 && (
				<div class="flex flex-wrap gap-2 mb-5">
					{tags.map((tag: string) => (
						<span class="tag-pill">{tag}</span>
					))}
				</div>
			)}
			<h1 class="font-display text-3xl sm:text-4xl lg:text-[2.75rem] font-bold text-primary leading-[1.15] tracking-tight mb-5">{title}</h1>
			<div class="flex items-center gap-3 text-sm text-text-muted">
				<FormattedDate date={pubDate} />
				{updatedDate && (
					<span class="text-border">|</span>
					<span>Updated: <FormattedDate date={updatedDate} /></span>
				)}
			</div>
			<span class="accent-bar mt-6"></span>
		</header>

		<!-- Hero image -->
		{heroImage && (
			<div class="mb-10 -mx-5 sm:mx-0">
				<Image
					src={heroImage}
					alt={title}
					widths={[640, 960, 1280, 1600]}
					sizes="(min-width: 768px) 768px, 100vw"
					loading="eager"
					fetchpriority="high"
					class="w-full rounded-none sm:rounded-2xl"
				/>
			</div>
		)}

		<!-- YouTube embed -->
		{youtubeId && <YouTubeEmbed id={youtubeId} title={title} />}

		<!-- Article content -->
		<div class="prose">
			<slot />
		</div>

		<!-- FAQ section (rendered from frontmatter, same source as schema) -->
		{faqs && faqs.length > 0 && (
			<section class="mt-16 pt-12 border-t border-border" aria-labelledby="faq-heading">
				<h2 id="faq-heading" class="font-display text-2xl sm:text-3xl font-bold text-primary mb-8">Frequently Asked Questions</h2>
				<div class="space-y-6">
					{faqs.map((faq: { question: string; answer: string }) => (
						<div>
							<h3 class="font-display text-lg font-semibold text-primary mb-2">{faq.question}</h3>
							<p class="text-text leading-relaxed">{faq.answer}</p>
						</div>
					))}
				</div>
			</section>
		)}

		<!-- Contact CTA -->
		<div class="mt-16">
			<ContactForm heading="Have questions about Austin real estate?" subheading="Reach out — I'm happy to help with your home search or sale." />
		</div>
	</article>
</BaseLayout>
