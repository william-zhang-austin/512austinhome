---
import BaseHead from '../components/BaseHead.astro';
import { PHONE, BROKERAGE, TREC_LICENSE } from '../consts';

interface Props {
	title: string;
	description: string;
	image?: string;
	canonical?: string;
}

const { title, description, image, canonical } = Astro.props;
const year = new Date().getFullYear();
const telHref = `tel:${PHONE.replace(/[^0-9+]/g, '')}`;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={image} canonical={canonical} />
		<!-- Paid-ad landing page: keep out of organic index, no link equity passed -->
		<meta name="robots" content="noindex, nofollow" />
		<!-- OpenAI / ChatGPT Ads conversion pixel -->
		<script is:inline>
			!function(w, d, s, u) {if (w.oaiq) return;var q = function() {q.q.push(arguments);};q.q = [];w.oaiq = q;var j = d.createElement(s);j.async = 1;j.src = u;var f = d.getElementsByTagName(s)[0];f.parentNode.insertBefore(j, f);}(window, document, "script", "https://bzrcdn.openai.com/sdk/oaiq.min.js");
			oaiq("init", {
				pixelId: "EY8b8YChhnw4y7bA3e3e8h",
				debug: false
			});
		</script>
	</head>
	<body class="min-h-screen flex flex-col">
		<!-- Slim header: brand + tap-to-call only. No nav, no exit links. -->
		<header class="sticky top-0 z-50 bg-surface/90 backdrop-blur-lg border-b border-border/60">
			<div class="max-w-4xl mx-auto px-5 sm:px-8 flex items-center justify-between h-[64px]">
				<span class="font-display text-lg sm:text-xl font-bold text-primary tracking-tight">512 Austin Home</span>
				<a
					href={telHref}
					class="inline-flex items-center gap-2 px-4 py-2 text-sm font-semibold text-accent border border-accent rounded-lg hover:bg-accent-light transition-all no-underline"
				>
					<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25Z" />
					</svg>
					<span class="hidden sm:inline">Call </span>{PHONE}
				</a>
			</div>
		</header>

		<main class="flex-1">
			<slot />
		</main>

		<!-- Slim legal footer: TREC-required notices only, no nav -->
		<footer class="bg-primary text-white/60 mt-20">
			<div class="h-px bg-gradient-to-r from-transparent via-accent to-transparent"></div>
			<div class="max-w-4xl mx-auto px-5 sm:px-8 py-10 text-xs space-y-4">
				<div class="flex flex-col sm:flex-row items-center justify-between gap-3">
					<span>&copy; {year} William Zhang | {BROKERAGE} | TREC #{TREC_LICENSE}</span>
					<a href={telHref} class="hover:text-accent transition-colors no-underline">{PHONE}</a>
				</div>
				<div class="flex flex-col sm:flex-row items-center justify-center gap-x-6 gap-y-2 text-center text-white/40">
					<a
						href="https://drive.google.com/file/d/1kDbiMbgScANjqs5e29LkyynBPBpJjF4v/view"
						target="_blank"
						rel="noopener"
						class="hover:text-accent transition-colors no-underline"
					>
						Texas Information About Brokerage Services (IABS)
					</a>
					<a
						href="https://www.trec.texas.gov/sites/default/files/pdf-forms/CN%201-4-1.pdf"
						target="_blank"
						rel="noopener"
						class="hover:text-accent transition-colors no-underline"
					>
						TREC Consumer Protection Notice
					</a>
				</div>
			</div>
		</footer>
	</body>
</html>
