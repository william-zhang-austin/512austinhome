---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchemaMarkup from '../../components/SchemaMarkup.astro';
import ContactForm from '../../components/ContactForm.astro';
import TidyCalEmbed from '../../components/TidyCalEmbed.astro';
import { PHONE, GBP_URL } from '../../consts';
import { CITIES } from '../../data/cities';
import { COMMUNITIES, priceRangeLabel, sqftRangeLabel, bedsLabel } from '../../data/communities';

export async function getStaticPaths() {
	return CITIES.map((city) => ({
		params: { city: city.slug },
		props: { city },
	}));
}

const { city } = Astro.props;
const communities = COMMUNITIES.filter(
	(c) => c.city === city.name || (city.slug === 'austin' && c.city === 'Austin') || (city.slug === 'dripping-springs' && c.city === 'Dripping Springs')
).sort((a, b) => a.priceFrom - b.priceFrom);

const title = `New Construction Homes in ${city.name}, TX — Save $5,000+ | 512 Austin Home`;
const description = `New construction homes in ${city.name}, Texas from ${city.newConstructionPriceRange}. Save at least $5,000 when you buy with buyer's agent William Zhang. Free representation at every major builder. Call (512) 766-3188.`;
---

<BaseLayout title={title} description={description}>
	<SchemaMarkup type="agent" />
	<SchemaMarkup type="faq" data={{ questions: city.newConstructionFaqs }} />
	<SchemaMarkup type="breadcrumb" data={{ items: [
		{ name: 'Home', url: '/' },
		{ name: 'New Construction', url: '/new-construction/' },
		{ name: `${city.name} New Construction`, url: `/new-construction/${city.slug}/` },
	] }} />

	<div class="max-w-4xl mx-auto px-5 sm:px-8 py-16">

		<!-- ABOVE THE FOLD: H1 + CTA -->
		<header class="mb-6">
			<h1 class="font-display text-3xl sm:text-5xl font-bold text-primary tracking-tight mb-4">New Construction Homes in {city.name}, TX</h1>
			<p class="text-lg sm:text-xl text-text-muted max-w-2xl mb-8">Save at least $5,000 on your new build in {city.name}. I negotiate builder incentives, rate buydowns, and upgrade credits at every major builder — and representation is free to you.</p>

			<div class="flex flex-col sm:flex-row gap-4 mb-4">
				<a href="#schedule" class="inline-flex items-center justify-center px-7 py-4 text-base font-semibold text-white bg-accent rounded-lg hover:bg-accent-hover transition-all no-underline">
					Get Your $5K+ Savings — Book a Call
				</a>
				<a href={`tel:${PHONE.replace(/[^0-9+]/g, '')}`} class="inline-flex items-center justify-center px-7 py-4 text-base font-semibold text-accent border-2 border-accent rounded-lg hover:bg-accent-light transition-all no-underline">
					Call {PHONE}
				</a>
			</div>
			<p class="text-sm text-text-muted">15-minute call. I'll share current builder incentives for {city.name} before we talk.</p>
		</header>

		<!-- SOCIAL PROOF -->
		<div class="bg-surface border border-border rounded-xl p-6 mb-12">
			<div class="flex items-center gap-3 mb-4">
				<div class="flex text-amber-400 text-lg" aria-label="5 out of 5 stars">
					<span>&#9733;&#9733;&#9733;&#9733;&#9733;</span>
				</div>
				<span class="text-sm text-text-muted">5.0 rating &middot; <a href={GBP_URL} target="_blank" rel="noopener" class="text-accent no-underline hover:underline">Google Reviews</a></span>
			</div>
			<blockquote class="text-sm text-text-muted italic leading-relaxed">
				"William has rich experience in finding good houses in Austin, TX. He also generously helped me negotiate and approach good deals."
			</blockquote>
			<p class="text-xs text-text-muted mt-2">— Curtis Hsu, Leander TX</p>
		</div>

		<!-- $100K+ SAVED IN 2026 -->
		<div class="bg-surface border border-border rounded-xl p-6 mb-12">
			<p class="text-accent font-semibold text-xs uppercase tracking-widest mb-2">2026 Results</p>
			<p class="text-primary font-display text-2xl font-bold mb-2">$100,000+ saved for my buyers in 2026 — and counting.</p>
			<p class="text-sm text-text-muted">Through rate buydowns, closing cost credits, and price negotiations across every major builder in the Austin metro. Each buyer saves $5,000-$30,000+ depending on the builder, community, and how much inventory they need to move.</p>
		</div>

		<!-- HOW I SAVE YOU MONEY -->
		<section class="mb-16">
			<h2 class="font-display text-2xl font-bold text-primary mb-6">How I Save You $5,000+ on {city.name} New Construction</h2>
			<div class="grid sm:grid-cols-2 gap-4">
				<div class="bg-surface border border-border rounded-xl p-6">
					<h3 class="font-display text-base font-bold text-primary mb-2">Past Sales Data You Can't Access</h3>
					<p class="text-sm text-text-muted">I run comps using MLS data that only licensed agents can see — actual past sale prices, not the list prices builders advertise. You'll know exactly what other buyers paid in the same community, so you never overpay.</p>
				</div>
				<div class="bg-surface border border-border rounded-xl p-6">
					<h3 class="font-display text-base font-bold text-primary mb-2">Stacked Builder Incentives</h3>
					<p class="text-sm text-text-muted">Builders offer rate buydowns, closing cost credits, and design center allowances — but they don't volunteer everything. I know what each {city.name} builder is currently offering and how to combine incentives that most buyers never hear about.</p>
				</div>
				<div class="bg-surface border border-border rounded-xl p-6">
					<h3 class="font-display text-base font-bold text-primary mb-2">Negotiation That Works</h3>
					<p class="text-sm text-text-muted">I negotiate with these builders every week. I know what they'll say yes to, when to push, and which incentive packages have the highest likelihood of getting approved — because I've done it before at the same community.</p>
				</div>
				<div class="bg-surface border border-border rounded-xl p-6">
					<h3 class="font-display text-base font-bold text-primary mb-2">Free to You</h3>
					<p class="text-sm text-text-muted">Builders pay the buyer-agent commission from their marketing budget. My representation costs you nothing — and typically saves you thousands. But you must register me before your first visit to a sales office.</p>
				</div>
			</div>
		</section>

		<!-- REGISTER WARNING -->
		<div class="bg-accent-light rounded-2xl p-6 sm:p-8 mb-16 border-l-4 border-accent">
			<h2 class="font-display text-xl font-bold text-primary mb-2">Register Me Before Your First Builder Visit</h2>
			<p class="text-text-muted text-sm leading-relaxed">If you walk into a {city.name} builder's sales office alone and sign anything — even a guest book — you may lose the ability to bring in a buyer's agent at that community. Text me the builder and community name before you go. Registration takes 60 seconds and protects your right to representation.</p>
		</div>

		<!-- COMMUNITIES LIST -->
		{communities.length > 0 && (
			<section class="mb-16">
				<h2 class="font-display text-2xl font-bold text-primary mb-6">New Construction Communities in {city.name}</h2>
				<div class="space-y-4">
					{communities.map((c) => (
						<a href={`/new-construction/communities/${c.slug}/`} class="block bg-surface border border-border rounded-xl p-6 no-underline hover:border-accent transition-colors group">
							<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 mb-2">
								<h3 class="font-display text-lg font-bold text-primary group-hover:text-accent transition-colors">{c.name}</h3>
								<span class="text-accent font-bold text-sm">{priceRangeLabel(c)}</span>
							</div>
							<p class="text-sm text-text-muted mb-3">{c.builder} &middot; {sqftRangeLabel(c)} &middot; {bedsLabel(c)} &middot; {c.schoolDistrict}</p>
							<p class="text-sm text-text-muted">{c.tagline}</p>
						</a>
					))}
				</div>
			</section>
		)}

		<!-- CITY CONTEXT -->
		<section class="prose mb-16">
			<h2>About {city.name} New Construction</h2>
			<p>{city.description}</p>

			<div class="not-prose grid sm:grid-cols-3 gap-4 my-6">
				<div class="bg-surface border border-border rounded-xl p-4 text-center">
					<p class="text-xs uppercase tracking-wider text-text-muted mb-1">Price Range</p>
					<p class="text-lg font-bold text-primary">{city.newConstructionPriceRange}</p>
				</div>
				<div class="bg-surface border border-border rounded-xl p-4 text-center">
					<p class="text-xs uppercase tracking-wider text-text-muted mb-1">Schools</p>
					<p class="text-lg font-bold text-primary">{city.schoolDistricts.join(', ')}</p>
				</div>
				<div class="bg-surface border border-border rounded-xl p-4 text-center">
					<p class="text-xs uppercase tracking-wider text-text-muted mb-1">To Downtown</p>
					<p class="text-lg font-bold text-primary">{city.commuteToDowntown}</p>
				</div>
			</div>
		</section>

		<!-- MID-PAGE CTA -->
		<div class="bg-primary rounded-2xl p-8 sm:p-10 mb-16 text-center text-white">
			<h2 class="font-display text-2xl font-bold mb-3">Save $5,000+ on Your {city.name} New Build</h2>
			<p class="text-white/70 mb-6 max-w-lg mx-auto">Book a 15-minute call. I'll share current builder incentives for {city.name} and register you before your first visit.</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<a href="#schedule" class="inline-flex items-center justify-center px-7 py-3.5 text-base font-semibold text-primary bg-white rounded-lg hover:bg-white/90 transition-all no-underline">
					Book Your Free Consultation
				</a>
				<a href={`tel:${PHONE.replace(/[^0-9+]/g, '')}`} class="inline-flex items-center justify-center px-7 py-3.5 text-base font-semibold text-white border-2 border-white/30 rounded-lg hover:bg-white/10 transition-all no-underline">
					Call {PHONE}
				</a>
			</div>
		</div>

		<!-- FAQ -->
		<section class="mb-16">
			<h2 class="font-display text-2xl font-bold text-primary mb-8">{city.name} New Construction FAQ</h2>
			<div class="space-y-4">
				{city.newConstructionFaqs.map((f, i) => (
					<details class="bg-surface rounded-xl border border-border p-6 group" open={i === 0}>
						<summary class="font-display font-semibold text-primary cursor-pointer list-none flex items-center justify-between gap-4">
							{f.question}
							<span class="text-text-muted group-open:rotate-180 transition-transform flex-shrink-0">&#9662;</span>
						</summary>
						<p class="mt-3 text-text-muted text-sm leading-relaxed">{f.answer}</p>
					</details>
				))}
			</div>
		</section>

		<!-- TIDYCAL -->
		<div id="schedule" class="mb-10 scroll-mt-20">
			<TidyCalEmbed
				heading={`Book a ${city.name} New Construction Consultation`}
				subheading={`Pick a time that works. I'll share current builder incentives for ${city.name} communities and register you as a client before your first visit — at no cost to you.`}
			/>
		</div>

		<!-- CONTACT FORM -->
		<ContactForm heading={`Questions about ${city.name} new construction?`} subheading={`Tell me your budget and what you're looking for. I'll send you a shortlist of ${city.name} communities with current pricing and incentives.`} />
	</div>
</BaseLayout>
