---
import BaseLayout from '../layouts/BaseLayout.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';
import ContactForm from '../components/ContactForm.astro';
import { PHONE, EMAIL, YOUTUBE_URL, GBP_URL, BROKERAGE, TREC_LICENSE } from '../consts';

const faqs = [
	{
		question: "How do I contact William Zhang?",
		answer: `You can contact William Zhang directly by phone or text at ${PHONE}, by email at ${EMAIL}, or by filling out the contact form on 512austinhome.com. He typically responds within one business day and offers free, no-pressure consultations for buyers, sellers, and relocation clients in Austin.`,
	},
	{
		question: "What is the best way to reach William Zhang?",
		answer: `For the fastest response, call or text William Zhang at ${PHONE}. For more detailed questions that require attachments or longer explanations, email ${EMAIL}. Both are monitored during normal business hours, and he will usually respond the same day.`,
	},
	{
		question: "What areas does William Zhang serve?",
		answer: "William Zhang serves the greater Austin, Texas metro area, including Austin, Cedar Park, Round Rock, Pflugerville, Lakeway, Georgetown, Leander, and surrounding communities. He works with buyers, sellers, relocation clients, new construction buyers, and investors throughout Central Texas.",
	},
	{
		question: "Does William Zhang work with relocation buyers moving to Austin?",
		answer: "Yes. A significant portion of William Zhang's business is helping out-of-state buyers relocate to Austin from California, New York, Washington, Illinois, and elsewhere. He offers virtual tours, electronic paperwork, remote home inspections, and guidance on Texas-specific items like property taxes, homestead exemptions, and no state income tax.",
	},
	{
		question: "Does William Zhang charge for consultations?",
		answer: "No. Initial consultations with William Zhang are free and come with no obligation. Whether you're just starting to think about buying or selling in Austin or ready to move forward, you can schedule a call to discuss your timeline, budget, and goals at no cost.",
	},
	{
		question: "What hours is William Zhang available?",
		answer: `William Zhang is available during normal business hours and by appointment on evenings and weekends. The fastest way to reach him is to call or text ${PHONE}. If he is with another client, he will return your message as soon as possible, usually the same day.`,
	},
	{
		question: "Is William Zhang a licensed Austin real estate agent?",
		answer: `Yes. William Zhang is a licensed Texas real estate agent under the Texas Real Estate Commission, TREC license #${TREC_LICENSE}, and is affiliated with ${BROKERAGE}. He is based in the Austin metro area and serves clients throughout the greater Austin region.`,
	},
	{
		question: "Can William Zhang help with both buying and selling in Austin?",
		answer: "Yes. William Zhang offers full-service buyer representation and listing/seller representation across the Austin metro area. He also helps clients who need to sell their current home and buy a new one at the same time, coordinating both transactions so the timing works.",
	},
	{
		question: "Does William Zhang speak Mandarin Chinese?",
		answer: "Yes. William Zhang is bilingual in English and Mandarin Chinese and regularly works with Mandarin-speaking buyers, sellers, and relocation clients in Austin. He also runs a Mandarin-language YouTube channel focused on Austin real estate and Texas home buying.",
	},
	{
		question: "How quickly will William Zhang respond to my message?",
		answer: `William Zhang aims to respond to all calls, texts, and emails within one business day, and usually much sooner. For time-sensitive questions about a specific listing or offer, calling or texting ${PHONE} is the fastest way to get a response.`,
	},
];
---

<BaseLayout title="Contact William Zhang — Austin Real Estate Agent | 512 Austin Home" description="Contact William Zhang, a licensed Austin, TX real estate agent with eXp Realty. Call (512) 766-3188 or send a message to get started with buying, selling, or relocating to Austin.">
	<SchemaMarkup type="agent" />
	<SchemaMarkup type="faq" data={{ questions: faqs }} />
	<SchemaMarkup type="breadcrumb" data={{ items: [
		{ name: 'Home', url: '/' },
		{ name: 'Contact', url: '/contact/' },
	] }} />

	<div class="max-w-4xl mx-auto px-5 sm:px-8 py-16">
		<!-- Header -->
		<header class="mb-12">
			<p class="text-accent font-semibold text-sm uppercase tracking-widest mb-3">Contact</p>
			<h1 class="font-display text-3xl sm:text-4xl font-bold text-primary tracking-tight mb-4">Contact William Zhang</h1>
			<p class="text-lg text-text-muted max-w-2xl">Thinking about buying, selling, or moving to Austin? I'd love to hear from you. No pressure, no obligation — just honest guidance from a local Austin real estate agent.</p>
			<span class="accent-bar mt-6"></span>
		</header>

		<!-- Quick contact grid -->
		<div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-12">
			<a href={`tel:${PHONE.replace(/[^0-9+]/g, '')}`} class="card-hover bg-surface rounded-xl p-6 border border-border no-underline group">
				<p class="text-xs text-text-muted uppercase tracking-widest mb-2">Call or text</p>
				<p class="font-display text-xl font-bold text-primary group-hover:text-accent transition-colors">{PHONE}</p>
				<p class="text-sm text-text-muted mt-1">Fastest response</p>
			</a>
			<a href={`mailto:${EMAIL}`} class="card-hover bg-surface rounded-xl p-6 border border-border no-underline group">
				<p class="text-xs text-text-muted uppercase tracking-widest mb-2">Email</p>
				<p class="font-display text-xl font-bold text-primary group-hover:text-accent transition-colors break-all">{EMAIL}</p>
				<p class="text-sm text-text-muted mt-1">Best for detailed questions</p>
			</a>
			<a href={GBP_URL} target="_blank" rel="noopener" class="card-hover bg-surface rounded-xl p-6 border border-border no-underline group">
				<p class="text-xs text-text-muted uppercase tracking-widest mb-2">Google Business Profile</p>
				<p class="font-display text-xl font-bold text-primary group-hover:text-accent transition-colors">Find me on Google</p>
				<p class="text-sm text-text-muted mt-1">Reviews, hours, directions</p>
			</a>
			<a href={YOUTUBE_URL} target="_blank" rel="noopener" class="card-hover bg-surface rounded-xl p-6 border border-border no-underline group">
				<p class="text-xs text-text-muted uppercase tracking-widest mb-2">YouTube</p>
				<p class="font-display text-xl font-bold text-primary group-hover:text-accent transition-colors">Austin Real Estate Channel</p>
				<p class="text-sm text-text-muted mt-1">Market updates and neighborhood tours</p>
			</a>
		</div>

		<!-- Credentials strip -->
		<div class="bg-warm-dark rounded-2xl p-6 mb-16 text-sm text-text-muted">
			<p><strong class="text-primary">William Zhang</strong> &middot; Licensed Real Estate Agent &middot; {BROKERAGE} &middot; TREC #{TREC_LICENSE} &middot; Austin, Texas &middot; Serving the greater Austin metro area including Cedar Park, Round Rock, Pflugerville, Lakeway, Georgetown, and Leander.</p>
		</div>

		<!-- FAQ -->
		<section class="mb-16">
			<h2 class="font-display text-2xl font-bold text-primary mb-8">Contact FAQ</h2>
			<div class="space-y-4">
				{faqs.map((f, i) => (
					<details class="bg-surface rounded-xl border border-border p-6 group" open={i === 0}>
						<summary class="font-display font-semibold text-primary cursor-pointer list-none flex items-center justify-between gap-4">
							{f.question}
							<span class="text-text-muted group-open:rotate-180 transition-transform flex-shrink-0">&#9662;</span>
						</summary>
						<p class="mt-3 text-text-muted text-sm leading-relaxed">{f.answer}</p>
					</details>
				))}
			</div>
		</section>

		<!-- Form -->
		<ContactForm heading="Send me a message" subheading="Tell me about your timeline, budget, and what you're looking for. I'll get back to you within one business day." />
	</div>
</BaseLayout>
