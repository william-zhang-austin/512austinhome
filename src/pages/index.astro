---
import BaseLayout from '../layouts/BaseLayout.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';
import ContactForm from '../components/ContactForm.astro';
import { SITE_DESCRIPTION, IDX_URL, PHONE } from '../consts';
import { getCollection } from 'astro:content';

const recentPosts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const neighborhoods = await getCollection('neighborhoods');
---

<BaseLayout title="Austin Real Estate Agent — Buy & Sell Homes | 512 Austin Home" description={SITE_DESCRIPTION}>
	<SchemaMarkup type="agent" />

	<!-- Hero -->
	<section class="relative bg-primary text-white overflow-hidden">
		<div class="max-w-6xl mx-auto px-5 sm:px-8 py-20 sm:py-28 lg:py-32">
			<div class="max-w-2xl animate-fade-up">
				<p class="text-accent font-semibold text-sm uppercase tracking-widest mb-4">Austin Real Estate Agent</p>
				<h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-bold leading-[1.1] tracking-tight mb-6">
					Find Your Home in Austin, Texas
				</h1>
				<p class="text-lg sm:text-xl text-white/70 leading-relaxed mb-8 max-w-xl">
					William Zhang is an Austin real estate agent who helps buyers and sellers navigate the Austin housing market with local expertise, data-driven guidance, and honest advice.
				</p>
				<div class="flex flex-col sm:flex-row gap-4">
					<a
						href={IDX_URL}
						target="_blank"
						rel="noopener"
						class="inline-flex items-center justify-center px-7 py-3.5 text-base font-semibold text-primary bg-white rounded-lg hover:bg-white/90 transition-all duration-200 no-underline"
					>
						Search Homes
					</a>
					<a
						href={`tel:${PHONE.replace(/[^0-9+]/g, '')}`}
						class="inline-flex items-center justify-center px-7 py-3.5 text-base font-semibold text-white border-2 border-white/30 rounded-lg hover:border-white/60 transition-all duration-200 no-underline"
					>
						Call {PHONE}
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Services -->
	<section class="max-w-6xl mx-auto px-5 sm:px-8 py-20">
		<div class="text-center mb-14">
			<h2 class="font-display text-3xl sm:text-4xl font-bold text-primary tracking-tight mb-4">How I Can Help</h2>
			<p class="text-text-muted max-w-xl mx-auto">Whether you're buying your first home or selling an investment property, I bring local market knowledge and a straightforward approach.</p>
		</div>

		<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
			<a href="/buy" class="card-hover bg-surface rounded-xl p-8 border border-border no-underline group">
				<div class="w-12 h-12 bg-accent-light rounded-lg flex items-center justify-center mb-5">
					<svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
					</svg>
				</div>
				<h3 class="font-display text-xl font-bold text-primary mb-2 group-hover:text-accent transition-colors">Buy a Home</h3>
				<p class="text-text-muted text-sm">From neighborhoods to negotiations, I'll guide you through every step of buying in Austin.</p>
			</a>

			<a href="/sell" class="card-hover bg-surface rounded-xl p-8 border border-border no-underline group">
				<div class="w-12 h-12 bg-green-light rounded-lg flex items-center justify-center mb-5">
					<svg class="w-6 h-6 text-green" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
					</svg>
				</div>
				<h3 class="font-display text-xl font-bold text-primary mb-2 group-hover:text-accent transition-colors">Sell Your Home</h3>
				<p class="text-text-muted text-sm">Market-backed pricing, professional marketing, and YouTube exposure to reach more buyers.</p>
			</a>

			<a href="/neighborhoods" class="card-hover bg-surface rounded-xl p-8 border border-border no-underline group">
				<div class="w-12 h-12 bg-accent-light rounded-lg flex items-center justify-center mb-5">
					<svg class="w-6 h-6 text-accent" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
						<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
					</svg>
				</div>
				<h3 class="font-display text-xl font-bold text-primary mb-2 group-hover:text-accent transition-colors">Explore Neighborhoods</h3>
				<p class="text-text-muted text-sm">In-depth guides to Austin, Cedar Park, Round Rock, and more — prices, schools, and lifestyle.</p>
			</a>
		</div>
	</section>

	<!-- Neighborhoods preview -->
	{neighborhoods.length > 0 && (
		<section class="bg-warm-dark py-20">
			<div class="max-w-6xl mx-auto px-5 sm:px-8">
				<div class="flex items-end justify-between mb-10">
					<div>
						<h2 class="font-display text-3xl font-bold text-primary tracking-tight mb-2">Austin Neighborhoods</h2>
						<p class="text-text-muted">Find the right area for your lifestyle and budget.</p>
					</div>
					<a href="/neighborhoods" class="hidden sm:inline-block text-accent font-semibold text-sm hover:text-accent-hover transition-colors no-underline">
						View all &rarr;
					</a>
				</div>
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
					{neighborhoods.slice(0, 6).map((n) => (
						<a href={`/neighborhoods/${n.id}`} class="card-hover bg-surface rounded-xl p-6 border border-border no-underline group">
							<h3 class="font-display text-lg font-bold text-primary mb-1 group-hover:text-accent transition-colors">{n.data.name}</h3>
							<p class="text-sm text-text-muted mb-3">{n.data.region}</p>
							<div class="flex items-center justify-between">
								<span class="text-sm font-semibold text-primary">Median: {n.data.medianPrice}</span>
								<span class="text-accent text-sm">&rarr;</span>
							</div>
						</a>
					))}
				</div>
			</div>
		</section>
	)}

	<!-- Recent blog posts -->
	{recentPosts.length > 0 && (
		<section class="max-w-6xl mx-auto px-5 sm:px-8 py-20">
			<div class="flex items-end justify-between mb-10">
				<div>
					<h2 class="font-display text-3xl font-bold text-primary tracking-tight mb-2">Austin Real Estate Insights</h2>
					<p class="text-text-muted">Market updates, buying tips, and neighborhood guides.</p>
				</div>
				<a href="/blog" class="hidden sm:inline-block text-accent font-semibold text-sm hover:text-accent-hover transition-colors no-underline">
					All posts &rarr;
				</a>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
				{recentPosts.map((post) => (
					<a href={`/blog/${post.id}`} class="card-hover bg-surface rounded-xl border border-border overflow-hidden no-underline group">
						<div class="p-6">
							{post.data.tags?.[0] && <span class="tag-pill mb-3">{post.data.tags[0]}</span>}
							<h3 class="font-display text-lg font-bold text-primary mb-2 group-hover:text-accent transition-colors">{post.data.title}</h3>
							<p class="text-sm text-text-muted line-clamp-2">{post.data.description}</p>
						</div>
					</a>
				))}
			</div>
		</section>
	)}

	<!-- Contact -->
	<section class="max-w-3xl mx-auto px-5 sm:px-8 pb-20">
		<ContactForm />
	</section>
</BaseLayout>
