---
import { YOUTUBE_URL, GBP_URL, IDX_URL, PHONE, EMAIL, BROKERAGE, TREC_LICENSE } from '../consts';
const year = new Date().getFullYear();
---

<footer class="bg-primary text-white/70 mt-24">
	<div class="h-px bg-gradient-to-r from-transparent via-accent to-transparent"></div>

	<div class="max-w-6xl mx-auto px-5 sm:px-8 py-16">
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-8">
			<!-- Brand -->
			<div class="sm:col-span-2 lg:col-span-1">
				<h3 class="font-display text-lg font-bold text-white mb-3 tracking-tight">512 Austin Home</h3>
				<p class="text-sm leading-relaxed max-w-xs">
					Your Austin real estate agent. Local market expertise, honest advice, and data-driven guidance for buyers and sellers.
				</p>
			</div>

			<!-- Navigation -->
			<div>
				<h3 class="text-xs font-semibold text-white uppercase tracking-widest mb-4">Explore</h3>
				<ul class="space-y-2.5 text-sm">
					<li><a href="/buy/" class="hover:text-accent transition-colors duration-200 no-underline">Buy a Home</a></li>
					<li><a href="/sell/" class="hover:text-accent transition-colors duration-200 no-underline">Sell Your Home</a></li>
					<li><a href="/relocate/" class="hover:text-accent transition-colors duration-200 no-underline">Moving to Austin</a></li>
					<li><a href="/new-construction/" class="hover:text-accent transition-colors duration-200 no-underline">New Construction</a></li>
					<li><a href="/neighborhoods/" class="hover:text-accent transition-colors duration-200 no-underline">Neighborhoods</a></li>
					<li><a href="/blog/" class="hover:text-accent transition-colors duration-200 no-underline">Blog</a></li>
					<li><a href="/reviews/" class="hover:text-accent transition-colors duration-200 no-underline">Reviews</a></li>
					<li><a href="/tech-employers/" class="hover:text-accent transition-colors duration-200 no-underline">Austin Tech Employers</a></li>
					<li><a href={IDX_URL} target="_blank" rel="noopener" class="hover:text-accent transition-colors duration-200 no-underline">Search Homes</a></li>
				</ul>
			</div>

			<!-- Connect -->
			<div>
				<h3 class="text-xs font-semibold text-white uppercase tracking-widest mb-4">Connect</h3>
				<ul class="space-y-2.5 text-sm">
					<li><a href={`tel:${PHONE.replace(/[^0-9+]/g, '')}`} class="hover:text-accent transition-colors duration-200 no-underline">{PHONE}</a></li>
					<li><a href={`mailto:${EMAIL}`} class="hover:text-accent transition-colors duration-200 no-underline">{EMAIL}</a></li>
					<li><a href={YOUTUBE_URL} target="_blank" rel="noopener" class="hover:text-accent transition-colors duration-200 no-underline">YouTube</a></li>
					<li><a href={GBP_URL} target="_blank" rel="noopener" class="hover:text-accent transition-colors duration-200 no-underline">Google Business Profile</a></li>
					<li><a href="/rss.xml" class="hover:text-accent transition-colors duration-200 no-underline">RSS Feed</a></li>
				</ul>
			</div>

			<!-- CTA -->
			<div>
				<h3 class="text-xs font-semibold text-white uppercase tracking-widest mb-4">Ready to Move?</h3>
				<p class="text-sm mb-4">Get personalized guidance for your Austin home search or sale.</p>
				<a
					href="/contact/"
					class="inline-block px-5 py-2.5 text-sm font-semibold text-primary bg-white rounded-lg hover:bg-white/90 transition-colors duration-200 no-underline"
				>
					Get in Touch
				</a>
			</div>
		</div>

		<!-- Bottom bar -->
		<div class="mt-14 pt-8 border-t border-white/10 text-xs text-white/40 space-y-4">
			<div class="flex flex-col sm:flex-row items-center justify-between gap-4">
				<span>&copy; {year} William Zhang | {BROKERAGE} | TREC #{TREC_LICENSE}</span>
				<span>512 Austin Home &mdash; Austin, Texas</span>
			</div>
			<div class="flex flex-col sm:flex-row items-center justify-center gap-x-6 gap-y-2 text-center">
				<a
					href="https://drive.google.com/file/d/1kDbiMbgScANjqs5e29LkyynBPBpJjF4v/view"
					target="_blank"
					rel="noopener"
					class="hover:text-accent transition-colors duration-200 no-underline"
				>
					Texas Information About Brokerage Services (IABS)
				</a>
				<a
					href="https://www.trec.texas.gov/sites/default/files/pdf-forms/CN%201-4-1.pdf"
					target="_blank"
					rel="noopener"
					class="hover:text-accent transition-colors duration-200 no-underline"
				>
					TREC Consumer Protection Notice
				</a>
			</div>
		</div>
	</div>
</footer>
