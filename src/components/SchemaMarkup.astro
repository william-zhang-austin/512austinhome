---
import { SITE_URL, PHONE, EMAIL, BROKERAGE, TREC_LICENSE, YOUTUBE_URL } from '../consts';

interface Props {
	type: 'agent' | 'article' | 'faq' | 'neighborhood';
	data?: Record<string, any>;
}

const { type, data = {} } = Astro.props;

const agentSchema = {
	"@context": "https://schema.org",
	"@type": "RealEstateAgent",
	"name": "William Zhang",
	"jobTitle": "Licensed Real Estate Agent",
	"url": SITE_URL,
	"telephone": PHONE,
	"email": EMAIL,
	"image": `${SITE_URL}/william-zhang.jpg`,
	"description": "Austin real estate agent William Zhang helps buyers and sellers navigate the Austin, TX housing market with local expertise, data-driven guidance, and honest advice.",
	"areaServed": [
		{ "@type": "City", "name": "Austin", "containedInPlace": { "@type": "State", "name": "Texas" } },
		{ "@type": "City", "name": "Cedar Park", "containedInPlace": { "@type": "State", "name": "Texas" } },
		{ "@type": "City", "name": "Round Rock", "containedInPlace": { "@type": "State", "name": "Texas" } },
		{ "@type": "City", "name": "Pflugerville", "containedInPlace": { "@type": "State", "name": "Texas" } },
		{ "@type": "City", "name": "Lakeway", "containedInPlace": { "@type": "State", "name": "Texas" } },
		{ "@type": "City", "name": "Georgetown", "containedInPlace": { "@type": "State", "name": "Texas" } },
		{ "@type": "City", "name": "Leander", "containedInPlace": { "@type": "State", "name": "Texas" } },
	],
	"worksFor": {
		"@type": "RealEstateAgent",
		"name": BROKERAGE,
	},
	"hasCredential": {
		"@type": "EducationalOccupationalCredential",
		"credentialCategory": "license",
		"name": "Texas Real Estate Sales Agent License",
		"recognizedBy": { "@type": "Organization", "name": "Texas Real Estate Commission (TREC)" },
		"identifier": TREC_LICENSE,
	},
	"alumniOf": {
		"@type": "CollegeOrUniversity",
		"name": "University of Texas at Austin",
	},
	"knowsLanguage": ["English", "Mandarin Chinese"],
	"sameAs": [
		YOUTUBE_URL,
	],
};

const localBusinessSchema = {
	"@context": "https://schema.org",
	"@type": "LocalBusiness",
	"name": "512 Austin Home — William Zhang, Realtor",
	"url": SITE_URL,
	"telephone": PHONE,
	"email": EMAIL,
	"address": {
		"@type": "PostalAddress",
		"addressLocality": "Austin",
		"addressRegion": "TX",
		"addressCountry": "US",
	},
	"geo": {
		"@type": "GeoCoordinates",
		"latitude": 30.2672,
		"longitude": -97.7431,
	},
	"openingHours": "Mo-Su 09:00-18:00",
	"priceRange": "$$",
};

function buildArticleSchema(d: Record<string, any>) {
	return {
		"@context": "https://schema.org",
		"@type": "Article",
		"headline": d.title,
		"description": d.description,
		"datePublished": d.pubDate,
		...(d.updatedDate && { "dateModified": d.updatedDate }),
		...(d.image && { "image": d.image }),
		"author": {
			"@type": "Person",
			"name": "William Zhang",
			"url": `${SITE_URL}/about`,
		},
		"publisher": {
			"@type": "Organization",
			"name": "512 Austin Home",
			"url": SITE_URL,
		},
		"mainEntityOfPage": {
			"@type": "WebPage",
			"@id": d.url || SITE_URL,
		},
		...(d.youtubeId && {
			"video": {
				"@type": "VideoObject",
				"name": d.title,
				"description": d.description,
				"uploadDate": d.pubDate,
				"embedUrl": `https://www.youtube.com/embed/${d.youtubeId}`,
				"thumbnailUrl": `https://img.youtube.com/vi/${d.youtubeId}/maxresdefault.jpg`,
			}
		}),
	};
}

function buildFaqSchema(d: Record<string, any>) {
	return {
		"@context": "https://schema.org",
		"@type": "FAQPage",
		"mainEntity": (d.questions || []).map((q: { question: string; answer: string }) => ({
			"@type": "Question",
			"name": q.question,
			"acceptedAnswer": {
				"@type": "Answer",
				"text": q.answer,
			},
		})),
	};
}

function buildNeighborhoodSchema(d: Record<string, any>) {
	return {
		"@context": "https://schema.org",
		"@type": "Place",
		"name": d.name,
		"description": d.description,
		"address": {
			"@type": "PostalAddress",
			"addressLocality": d.name,
			"addressRegion": "TX",
			"addressCountry": "US",
		},
	};
}

const schemas: string[] = [];

if (type === 'agent') {
	schemas.push(JSON.stringify(agentSchema));
	schemas.push(JSON.stringify(localBusinessSchema));
}
if (type === 'article') {
	schemas.push(JSON.stringify(buildArticleSchema(data)));
}
if (type === 'faq') {
	schemas.push(JSON.stringify(buildFaqSchema(data)));
}
if (type === 'neighborhood') {
	schemas.push(JSON.stringify(buildNeighborhoodSchema(data)));
}
---

{schemas.map((schema) => (
	<script is:inline type="application/ld+json" set:html={schema} />
))}
