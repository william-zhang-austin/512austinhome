---
interface Props {
	heading?: string;
	subheading?: string;
	formId?: string;
}

const {
	heading = 'Get in Touch',
	subheading = 'Whether you\'re buying, selling, or just exploring — I\'m here to help.',
	formId = 'RGBKxQ',
} = Astro.props;

const embedSrc = `https://tally.so/embed/${formId}?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1`;
---

<section id="contact" class="bg-warm-dark rounded-2xl p-6 sm:p-10">
	<h2 class="font-display text-2xl font-bold text-primary mb-2">{heading}</h2>
	<p class="text-text-muted mb-6">{subheading}</p>

	<iframe
		data-tally-src={embedSrc}
		loading="lazy"
		width="100%"
		height="500"
		frameborder="0"
		marginheight="0"
		marginwidth="0"
		title={heading}
		class="w-full block"
	></iframe>

	<script is:inline src="https://tally.so/widgets/embed.js" async></script>
	<script is:inline>
		// Fallback: if the Tally widget script hasn't hydrated iframes by the time
		// the user sees the page, set src directly so the form still loads.
		(function () {
			function load() {
				document.querySelectorAll('iframe[data-tally-src]:not([src])').forEach(function (el) {
					el.src = el.getAttribute('data-tally-src');
				});
			}
			if (typeof window.Tally === 'undefined') {
				if (document.readyState !== 'loading') load();
				else document.addEventListener('DOMContentLoaded', load);
			}
		})();
	</script>
</section>
