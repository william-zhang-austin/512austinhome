{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.512austinhome.com"
        }
      ],
      "destination": "https://512austinhome.com/$1",
      "permanent": true
    },
    {
      "source": "/homes/listing/:path*",
      "destination": "/buy/",
      "permanent": true
    },
    {
      "source": "/homes/:path*",
      "destination": "/buy/",
      "permanent": true
    },
    {
      "source": "/provision-error",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/provision-error/",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/feed",
      "destination": "/rss.xml",
      "permanent": true
    },
    {
      "source": "/feed/",
      "destination": "/rss.xml",
      "permanent": true
    },
    {
      "source": "/wp-sitemap.xml",
      "destination": "/sitemap-index.xml",
      "permanent": true
    },
    {
      "source": "/wp-sitemap:path*",
      "destination": "/sitemap-index.xml",
      "permanent": true
    },
    {
      "source": "/wp-content/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/wp-includes/:path*",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/wp-json/:path*",
      "destination": "/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/homes/:path*",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    },
    {
      "source": "/homes/listing/:path*",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ]
}
